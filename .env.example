# Core app
DATABASE_URL=sqlite:///./quests.db
SESSION_SECRET_KEY=replace-this-with-a-secret

# Firebase credentials: либо полный JSON в переменной, либо путь к файлу
# Например: export FIREBASE_CREDENTIALS="{...whole json...}"
FIREBASE_CREDENTIALS=
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

DEBUG=true
FIRESTORE_ENABLED=false

# Gemini / assistant
GEMINI_API_KEY=your-gemini-api-key
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.0-flash
GEMINI_INTENT_MODEL=gemini-2.0-flash-lite
GEMINI_AUDIO_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT_SECONDS=30
GEMINI_MAX_RETRIES=3
ASSISTANT_CONTEXT_MESSAGES=8
ASSISTANT_MEMORY_DB_PATH=assistant_memory.db
GOOGLE_CALENDAR_SERVICE_ACCOUNT_FILE=path/to/google-calendar-service-account.json
GOOGLE_CALENDAR_ID=primary

PERPLEXITY_API_KEY=text
OPENAI_API_KEY=text
OPENROUTER_API_KEY=text